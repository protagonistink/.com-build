# Sanity Studio (required)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_sanity_project_id
NEXT_PUBLIC_SANITY_DATASET=production

# Studio route protection (required in production)
STUDIO_BASIC_AUTH_USERNAME=change-me
STUDIO_BASIC_AUTH_PASSWORD=change-me

# Loom submission endpoint
CRAFT_LINK_ID=your_craft_link_id
CRAFT_COLLECTION_ID=your_craft_collection_id

# Notion integration
NOTION_TOKEN=your_notion_token
NOTION_DATABASE_ID=your_notion_database_id
