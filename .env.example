# Sanity Studio (required)
NEXT_PUBLIC_SANITY_PROJECT_ID=your_sanity_project_id
NEXT_PUBLIC_SANITY_DATASET=production

# Required Asana destination for Story Loom submissions
ASANA_ACCESS_TOKEN=your_asana_personal_access_token
ASANA_PROJECT_ID=your_asana_project_gid
ASANA_SECTION_ID=

# Optional Notion fan-out — if set, submissions are also added to Notion
NOTION_TOKEN=your_notion_integration_token
NOTION_DATABASE_ID=your_notion_database_id

# Optional Make.com webhook — if set, gets a non-blocking copy of submissions
MAKE_LOOM_WEBHOOK_URL=https://hook.us2.make.com/your_webhook_id

# Dubsado booking link for the $1,500 Story Audit
# Add this when the Dubsado proposal flow is ready
NEXT_PUBLIC_DUBSADO_URL=

# Optional Cloudflare Turnstile bot protection
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Beehiiv newsletter signup
BEEHIIV_API_KEY=your_beehiiv_api_key
BEEHIIV_PUBLICATION_ID=pub_77861931-514b-4fbb-b6d3-42a0fc9c9ef5
